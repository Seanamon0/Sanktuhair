<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sankhtuhair — Sanctuaire de ta Couronne</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#0F2922;--bdc:#172f25;--bdp:#0a1f18;--bmd:#0e2820;
      --or:#c9a96e;--orl:#e8c98a;--ord:rgba(201,169,110,.35);
      --tx:#e8dcc8;--txs:rgba(232,220,200,.82);--txm:rgba(232,220,200,.55);
      --bo:rgba(201,169,110,.22);--ok:#5ecb8a;
      --beige:#d4b896;--beige2:#e8cfb0;
      --rp:50px;--rc:18px;--rs:10px;--tr:.3s cubic-bezier(.4,0,.2,1)
    }
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--tx);font-family:'DM Sans',sans-serif;font-weight:300;line-height:1.65;overflow-x:hidden;-webkit-font-smoothing:antialiased}
    .lbl{font-size:.67rem;letter-spacing:.4em;text-transform:uppercase;color:var(--or)}
    .reveal{opacity:0;transform:translateY(30px);transition:opacity .7s ease,transform .7s ease}
    .reveal.in{opacity:1;transform:translateY(0)}
    
    nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:1rem 2rem;display:flex;align-items:center;justify-content:space-between;backdrop-filter:blur(14px);background:rgba(14,40,32,.88);border-bottom:1px solid var(--bo)}
    .nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.2rem;color:var(--or);letter-spacing:.12em;display:flex;align-items:center;gap:.7rem}
    .nav-logo img{width:32px;height:32px;border-radius:50%;object-fit:cover;border:1px solid var(--ord)}
    
    .hero{min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:7rem 1.5rem 4rem;position:relative;overflow:hidden}
    .hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 55% at 50% 45%,rgba(201,169,110,.09) 0%,transparent 70%);pointer-events:none}
    .bot{position:absolute;pointer-events:none}
    .hero-logo{width:clamp(90px,14vw,140px);height:clamp(90px,14vw,140px);object-fit:cover;border-radius:50%;border:2px solid var(--ord);margin-bottom:1.5rem;box-shadow:0 0 40px rgba(201,169,110,.2);opacity:0;animation:fadeIn 1s ease .2s forwards}
    .hero-ey{font-size:.67rem;letter-spacing:.42em;text-transform:uppercase;color:var(--or);margin-bottom:1.2rem;opacity:0;animation:fadeUp .8s ease .4s forwards}
    .hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(4rem,15vw,9.5rem);font-weight:300;line-height:.95;letter-spacing:.06em;opacity:0;animation:fadeUp .9s ease .6s forwards}
    .hero-title .ac{color:var(--or);font-style:italic}
    .hero-sub{font-family:'Cormorant Garamond',serif;font-size:clamp(1rem,3.5vw,1.4rem);font-style:italic;font-weight:300;color:var(--txm);max-width:460px;margin:1.4rem auto 0;opacity:0;animation:fadeUp .9s ease .8s forwards}
    .hero-message{opacity:0;animation:fadeUp .9s ease 1s forwards;display:flex;flex-direction:column;align-items:center;gap:1.2rem;margin-top:2.5rem;text-align:center}
    .hero-message p{font-size:1.05rem;color:var(--txs);line-height:1.8;max-width:560px}
    
    .btn-gold{display:inline-flex;align-items:center;gap:.5rem;padding:1.1rem 2.8rem;background:var(--beige);color:#0F2922;font-family:'DM Sans',sans-serif;font-size:.8rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;border:none;border-radius:var(--rp);cursor:pointer;transition:all var(--tr);box-shadow:0 6px 28px rgba(212,184,150,.25);margin-top:1.5rem}
    .btn-gold:hover{transform:translateY(-3px);box-shadow:0 14px 40px rgba(212,184,150,.4);background:var(--beige2)}
    
    footer{padding:3rem 1.5rem;text-align:center;border-top:1px solid var(--bo)}
    .fl{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--or);letter-spacing:.12em;margin-bottom:.6rem;display:flex;align-items:center;justify-content:center;gap:.8rem}
    .fl img{width:30px;height:30px;border-radius:50%;object-fit:cover;border:1px solid var(--ord)}
    footer p{font-size:.82rem;color:var(--txm);line-height:1.8}
    footer a{cursor:pointer!important;pointer-events:all!important}
    
    .dv{display:flex;align-items:center;gap:1.2rem;padding:2rem 1.5rem;max-width:700px;margin:0 auto}
    .dl{flex:1;height:1px;background:var(--bo)}
    .ds{color:var(--or);font-size:1rem;opacity:.5}
    
    .email-section{opacity:0;animation:fadeUp .9s ease 1.3s forwards;margin-top:2rem;width:100%;max-width:460px}
    .email-form{display:flex;gap:.5rem;margin-top:1.2rem;flex-direction:column}
    .email-form input{padding:.85rem 1.2rem;background:transparent;border:1.5px solid var(--ord);border-radius:var(--rs);color:var(--tx);font-family:'DM Sans',sans-serif;font-size:.95rem;outline:none;transition:border-color var(--tr)}
    .email-form input::placeholder{color:var(--txm)}
    .email-form input:focus{border-color:var(--or)}
    .email-submit{display:inline-flex;padding:.85rem 1.5rem;background:var(--or);color:var(--bg);font-family:'DM Sans',sans-serif;font-size:.8rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;border:none;border-radius:var(--rp);cursor:pointer;transition:all var(--tr);box-shadow:0 4px 16px rgba(201,169,110,.2)}
    .email-submit:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(201,169,110,.3);background:var(--orl)}
    .email-ok{display:none;text-align:center;margin-top:1rem;color:var(--or);font-size:.9rem}
    .email-ok.show{display:block}
    
    @keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}
    
    @media(max-width:480px){
      nav{padding:.7rem 1.2rem}
      .hero{padding:5rem 1rem 3rem}
      .hero-title{font-size:3rem}
      .email-form{gap:.4rem}
    }
  </style>
</head>
<body>

<nav>
  <div class="nav-logo">
    <img src="https://raw.githubusercontent.com/Seanamon0/Sanktuhair/main/logo" alt="Logo">
    Sankhtuhair
  </div>
</nav>

<header class="hero" id="accueil">
  <svg class="bot" style="right:-20px;top:0;width:min(360px,38vw);opacity:.12" viewBox="0 0 280 580" fill="none">
    <path d="M140 580C138 460 108 360 126 240C136 178 162 110 140 30" stroke="#c9a96e" stroke-width="2" fill="none"/>
    <path d="M138 300C88 272 32 288 6 250C-16 218 18 178 58 192C38 162 52 132 82 146C72 114 96 96 118 116C114 82 140 66 160 90C174 62 202 70 200 100C226 88 240 114 226 134C252 134 260 162 242 176C256 198 248 226 226 228C220 256 198 272 172 266C165 292 150 305 138 300Z" fill="#c9a96e" opacity=".16"/>
    <ellipse cx="108" cy="190" rx="14" ry="21" transform="rotate(-18 108 190)" fill="#0F2922" opacity=".55"/>
    <ellipse cx="160" cy="166" rx="11" ry="17" transform="rotate(12 160 166)" fill="#0F2922" opacity=".55"/>
  </svg>
  
  <img class="hero-logo" src="https://raw.githubusercontent.com/Seanamon0/Sanktuhair/main/logo" alt="Sankhtuhair">
  <p class="hero-ey">Sanctuaire Capillaire · Fondé par Élodie</p>
  <h1 class="hero-title">SANKTU<span class="ac">hair</span></h1>
  <p class="hero-sub">"Va chercher dans ton passé ce qui te rendra plus fort demain"</p>
  
  <div class="hero-message">
    <p>🌿 Nous prenons soin du sanctuaire.</p>
    <p>De nouvelles révélations arrivent en août.</p>
    <button class="btn-gold" onclick="document.querySelector('.email-section').scrollIntoView({behavior:'smooth'})">Me prévenir</button>
  </div>
</header>

<div class="dv"><div class="dl"></div><span class="ds">✦</span><div class="dl"></div></div>

<section class="email-section" style="display:flex;flex-direction:column;align-items:center;padding:0 1.5rem">
  <p class="lbl">Recevoir l'Ordonnance en Premier</p>
  <p style="font-size:1.1rem;color:var(--txs);margin-bottom:1.5rem;text-align:center">Laisse-nous ton mail pour être averti·e en priorité</p>
  
  <form class="email-form" onsubmit="handleEmail(event)" style="width:100%;max-width:380px">
    <input type="email" placeholder="ton-adresse@email.com" id="emailInput" required>
    <button type="submit" class="email-submit" id="submitBtn">Me prévenir</button>
  </form>
  
  <div class="email-ok" id="successMsg">
    ✨ Merci! On te contactera dès le lancement.
  </div>
</section>

<footer>
  <div class="fl">
    <img src="https://raw.githubusercontent.com/Seanamon0/Sanktuhair/main/logo" alt="Logo">
    Sankhtuhair
  </div>
  <p>Sanctuaire Capillaire — Fondé par Élodie</p>
  <div style="display:flex;justify-content:center;align-items:center;gap:1.5rem;margin-top:1rem;flex-wrap:wrap">
    <a href="https://www.instagram.com/sanktuhair?igsh=dmllZ2l1eXpxZzFk&utm_source=qr" target="_blank" rel="noopener" style="display:flex;align-items:center;gap:.45rem;color:var(--or);text-decoration:none;font-size:.82rem;opacity:.8;transition:opacity .2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=.8">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
      @sanktuhair
    </a>
    <span style="color:var(--bo);opacity:.4">·</span>
    <a href="mailto:sanktuhair@gmail.com" style="display:flex;align-items:center;gap:.45rem;color:var(--or);text-decoration:none;font-size:.82rem;opacity:.8;transition:opacity .2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=.8">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
      sanktuhair@gmail.com
    </a>
  </div>
  <p style="margin-top:1rem;opacity:.4">Propulsé par Seanamon · Sankofah à venir</p>
</footer>

<script>
  function handleEmail(e) {
    e.preventDefault();
    const email = document.getElementById('emailInput').value;
    const btn = document.getElementById('submitBtn');
    
    btn.disabled = true;
    btn.textContent = 'Envoyé ✓';
    
    console.log('Email collecté:', email);
    
    setTimeout(() => {
      document.getElementById('emailInput').style.display = 'none';
      btn.style.display = 'none';
      document.getElementById('successMsg').classList.add('show');
    }, 800);
  }
</script>

</body>
</html>
